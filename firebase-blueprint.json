{
  "entities": {
    "InventoryItem": {
      "title": "Inventory Item",
      "description": "A pharmaceutical product in stock",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "currentStock": { "type": "number" },
        "forecastedDemand": { "type": "number" },
        "reorderPoint": { "type": "number" },
        "reorderQuantity": { "type": "number" },
        "status": { "type": "string", "enum": ["In Stock", "Low Stock", "Out of Stock", "Overstock"] },
        "lastRestockDate": { "type": "string" },
        "daysOfSupply": { "type": "number" }
      },
      "required": ["id", "name", "currentStock", "reorderPoint", "status"]
    },
    "DashboardStats": {
      "title": "Dashboard Stats",
      "description": "Aggregated statistics for the dashboard",
      "type": "object",
      "properties": {
        "totalRevenue": { "type": "number" },
        "revenueChange": { "type": "string" },
        "growth": { "type": "number" },
        "growthChange": { "type": "string" },
        "topProduct": { "type": "string" },
        "topProductChange": { "type": "string" },
        "marketHealth": { "type": "number" },
        "marketHealthChange": { "type": "string" }
      }
    },
    "SalesRecord": {
      "title": "Sales Record",
      "description": "A record of a pharmaceutical sale",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "amount": { "type": "number" },
        "quantity": { "type": "number" },
        "timestamp": { "type": "string" },
        "region": { "type": "string" }
      },
      "required": ["id", "productId", "amount", "quantity", "timestamp"]
    }
  },
  "firestore": {
    "/inventory/{itemId}": {
      "schema": "InventoryItem",
      "description": "Collection of inventory items"
    },
    "/stats/dashboard": {
      "schema": "DashboardStats",
      "description": "Singleton document for dashboard statistics"
    },
    "/sales/{saleId}": {
      "schema": "SalesRecord",
      "description": "Collection of sales records"
    }
  }
}
